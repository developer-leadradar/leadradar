# Supabase - From supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=https://leadradar.cim-edge.com

# Random secret to protect cron job endpoints (generate with: openssl rand -hex 32)
CRON_SECRET=

# Google Places API - console.cloud.google.com (enables ~4000-8000 searches/month on $200 free credit)
GOOGLE_PLACES_API_KEY=

# Yelp Fusion API - fusion.yelp.com (500 free calls/day)
YELP_API_KEY=

# Apify - console.apify.com ($5/month free credit for scraping non-API platforms)
APIFY_API_TOKEN=

# Resend - resend.com/api-keys (3,000 emails/month free)
RESEND_API_KEY=

# Twilio - twilio.com/console (free trial credit; SMS is optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Hunter.io - hunter.io/api-keys (25 free searches/month - used only on user request)
HUNTER_API_KEY=
